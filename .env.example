# Supabase (Pflicht für Cloud-Speicher)
VITE_SUPABASE_URL=https://cwymmgfstfkgaiatbsev.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key-hier

# Moderator-Schlüssel nur serverseitig in Supabase Secrets: MODERATOR_KEY
# (Login über Edge Function moderator-auth — nicht als VITE_* im Client)

# Forum-Passwort nur serverseitig in Supabase Secrets: FORUM_PASSWORD
# (nicht als VITE_* — wird in Edge Function forum-auth geprüft)

# Cloudflare R2 — öffentliche Basis-URL für Audio/Cover (Cached Egress sparen)
VITE_R2_PUBLIC_URL=https://pub-a6d3efc7833c4556b272d9c2695e3d17.r2.dev

# Edge Functions (nach Deploy — für Suno-Links in Production)
VITE_AUDIO_RESOLVER_URL=https://cwymmgfstfkgaiatbsev.supabase.co/functions/v1/resolve-audio
VITE_AUDIO_PROXY_URL=https://cwymmgfstfkgaiatbsev.supabase.co/functions/v1/proxy-audio

# Lokal (npm run dev): /api/resolve-audio und /api/proxy-audio sind automatisch aktiv.

# Cloudflare Turnstile (Checkbox auf „Song einreichen“)
VITE_TURNSTILE_SITE_KEY=dein-turnstile-site-key
# Secret nur in Supabase Edge Function Secrets: TURNSTILE_SECRET_KEY

# Optional: PayPal-Spendenlink (Standard ist in src/config/legal.ts hinterlegt)
# VITE_PAYPAL_DONATE_URL=https://www.paypal.com/donate/?hosted_button_id=...
